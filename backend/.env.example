# =============================================
# WellNest Healthcare - Backend Environment
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Application Configuration
PORT=5000
BASE_BACKEND_URL=http://localhost:5000/api

# -----------------------------------------------
# MongoDB Configuration
# -----------------------------------------------
# Use a local MongoDB instance or a MongoDB Atlas cloud connection string
MONGO_URI=mongodb://localhost:27017/healthcare

# -----------------------------------------------
# JWT Authentication
# -----------------------------------------------
# Use a long, random string for the secret key (e.g., run: openssl rand -hex 64)
JWT_SECRET_KEY=your_super_secret_jwt_key_replace_this
JWT_TIMEOUT=1d

# -----------------------------------------------
# Gemini AI API (Google Generative Language)
# -----------------------------------------------
# Required for pre-visit symptom triage and post-visit patient summaries
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to run in fallback/mock mode (no AI summaries)
GEMINI_API_KEY=

# -----------------------------------------------
# Email / SMTP (Nodemailer)
# -----------------------------------------------
# If left blank, the EmailService will print emails to the console (mock mode)
# For Gmail: Enable 2FA and use an App Password: https://myaccount.google.com/apppasswords
EMAIL_ID=your_smtp_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# -----------------------------------------------
# Google OAuth 2.0 (for Google Calendar & Google Login)
# -----------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match the value of GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/callback
