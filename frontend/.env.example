# =============================================
# WellNest Healthcare - Frontend Environment
# =============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local
#
# NOTE: All variables exposed to the browser MUST be prefixed with NEXT_PUBLIC_

# -----------------------------------------------
# Backend API URL
# -----------------------------------------------
# Point this to wherever your backend is running
# Default for local development: http://localhost:5000/api/v1
NEXT_PUBLIC_BACKEND_URI=http://localhost:5000/api/v1

# -----------------------------------------------
# Google OAuth Client ID (for Google Sign-In button)
# -----------------------------------------------
# Must match the GOOGLE_CLIENT_ID value in the backend .env
# Create credentials at: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
